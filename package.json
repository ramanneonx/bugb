{
  "name": "bug-bounty-workspace",
  "version": "1.0.0",
  "description": "bugbOS — Elite Bug Bounty Operating System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "author": "ramanneonx",
  "license": "ISC",
  "build": {
    "appId": "com.ramanneonx.bugbos",
    "productName": "bugbOS",
    "copyright": "Copyright © 2026 ramanneonx",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "gdrive-config.json",
      "src/**/*",
      "!src/**/*.map"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
